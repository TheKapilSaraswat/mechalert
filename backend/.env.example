# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
WEBHOOK_SECRET=change-this-to-a-random-string
CORS_ORIGIN=http://localhost:5173,https://mechalert.app
BASE_URL=http://localhost:5173

# Database
DATABASE_PATH=./data/mechmarket.db
DB_BACKUP_DIR=./backups
DB_MAX_BACKUPS=48

# AI Scoring (optional - get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Stripe (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx

# Razorpay (test mode - get keys at https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_AMOUNT_MONTHLY=39900
RAZORPAY_AMOUNT_YEARLY=399900
# Webhook secret: set in Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET=

# PayPal (test mode - get credentials at https://developer.paypal.com/dashboard)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true
PAYPAL_PRICE_MONTHLY=5.00
PAYPAL_PRICE_YEARLY=48.00
PAYPAL_WEBHOOK_ID=

# Email (SMTP) - leave empty for Ethereal dev mode
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@mechalert.app

# Rate Limiting
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
SEARCH_RATE_LIMIT_MAX=30
REQUEST_TIMEOUT_MS=30000

# Scanners (set to false to disable specific sources)
ENABLE_EBAY_SCANNER=true
ENABLE_SLICKDEALS_SCANNER=true
ENABLE_FACEBOOK_SCANNER=true
ENABLE_CRAIGSLIST_SCANNER=true
ENABLE_OFFERUP_SCANNER=true
SCAN_INTERVAL_MINUTES=10

# Database maintenance
ENABLE_DB_BACKUP=true

# Logging
LOG_LEVEL=info
LOG_FILE=

# Error Monitoring (Sentry - get DSN at https://sentry.io)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate limiting for all endpoints
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001